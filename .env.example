# =========================================================
# OrbitApply — Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to version control.
# .env MUST be listed in .gitignore before any git add.
# =========================================================

# Anthropic Claude SDK — required for all agents (ORBI, TAILOR, COACH, SCOUT, RECON, LEDGER, GUARDIAN)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tavily — web search for SCOUT job discovery and RECON company intel
TAVILY_API_KEY=your_tavily_api_key_here

# Server
PORT=3000
NODE_ENV=development
