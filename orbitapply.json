{
  "version": "1.0.0",
  "agents": {
    "defaults": {
      "model": "claude-haiku-4-5-20251001",
      "subagents": {
        "maxDepth": 2,
        "maxConcurrent": 4
      }
    },
    "overrides": {
      "orbi": {
        "model": "claude-sonnet-4-20250514"
      },
      "tailor": {
        "model": "claude-sonnet-4-20250514"
      },
      "coach": {
        "model": "claude-sonnet-4-20250514"
      }
    }
  },
  "budget": {
    "dailyLimitUSD": 5,
    "hardStop": true,
    "alertAtUSD": 3
  },
  "guardian": {
    "maxAppliesPerDay": 15,
    "humanPauseFields": [
      "salary",
      "diversity",
      "custom_essay",
      "security_clearance",
      "disability",
      "gender",
      "race",
      "ethnicity",
      "veteran",
      "signature",
      "certify",
      "attestation"
    ],
    "rateLimitMs": 45000
  },
  "sessions": {
    "storePath": "./sessions/sessions.json"
  },
  "memory": {
    "profilePath": "./memory/profile.json",
    "protectedPath": "./memory/protected.json",
    "blacklistPath": "./memory/blacklist.json"
  },
  "credentials": {
    "authProfilesPath": "./credentials/auth-profiles.json"
  },
  "logs": {
    "path": "./logs/run.log",
    "level": "info"
  },
  "workspaces": {
    "scout": "./workspace-scout",
    "recon": "./workspace-recon",
    "tailor": "./workspace-tailor",
    "submit": "./workspace-submit",
    "ledger": "./workspace-ledger",
    "coach": "./workspace-coach"
  },
  "outputFolder": "./Apply",
  "submit": {
    "autoSubmit": false,
    "headless": true,
    "screenshotOnEachPage": true,
    "maxSubmitRetries": 1,
    "unsupportedPlatforms": ["workday", "icims"]
  }
}